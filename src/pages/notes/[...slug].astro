---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
---

<Layout title={note.data.title}>
  <nav class="mb-8">
    <a href="/Notes/" class="no-underline text-md font-typewriter hover:underline"
      >← Back to notes</a
    >
  </nav>

  <article>
    <h1 class="text-[var(--color-heading)] dark:text-[var(--color-heading-dark)] text-5xl font-typewriter">
      {note.data.title}
    </h1>
    <p class="text-gray-500 text-sm mb-8"></p>
    <div
      class="prose dark:prose-invert max-w-none text-xl leading-8 tracking-wide prose-ul:list-outside prose-li:mb-6"
    >
      <Content />
    </div>
  </article>
</Layout>
