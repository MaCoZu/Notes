---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return (await getCollection("notes")).map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
---

<Layout title={note.data.title}>
  <nav class="mb-8">
    <a href="/Notes/" class="no-underline font-typewriter hover:underline">
      ← Back to notes
    </a>
  </nav>

  <article>
    <h1 class="text-5xl font-typewriter text-heading dark:text-heading-dark mb-2">
      {note.data.title}
    </h1>
    <p class="text-gray-500 text-sm mb-8">{note.data.date.toISOString().split('T')[0]}</p>
    <div class="prose dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>
</Layout>
