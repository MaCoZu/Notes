---
import ThemeIcon from "../components/ThemeIcon.astro";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = "/Notes";
const basePath = base + "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={basePath + "mz_logo.svg"} />
    <title>{title}</title>
    <link
      rel="preload"
      href={basePath + "fonts/typewcond_regular.otf"}
      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href={basePath + "fonts/typewcond_bold.otf"}
      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href={basePath + "fonts/georgia.woff2"}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={basePath + "fonts/FiraCodeNerdFont-Light.ttf"}
      as="font"
      type="font/ttf"
      crossorigin
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css"
    />
  </head>
  <body
    class="bg-(--color-bg) text-text dark:bg-bg-dark dark:text-(--color-text-dark)"
  >
    <div class="min-h-screen flex flex-col">
      <header
        id="site-header"
        class="border-b border-black/5 dark:border-white/10"
      >
        <div
          class="mx-auto px-4 sm:px-8 py-4 flex justify-between items-center"
        >
          <a href={basePath} class="flex items-center gap-4 no-underline">
            <svg
              aria-label="Logo"
              width="44"
              height="48"
              class="w-11 h-12 text-heading dark:text-(--color-heading-dark)"
              viewBox="0 0 21.85 24"
            >
              <g transform="scale(0.08572244)">
                <path
                  fill="currentColor"
                  d="M 251.79,41.483351 16.41,276.86335 c -1.15,1.15 -0.33,3.11 1.29,3.11 h 235.37 c 1.01,0 1.82,-0.82 1.82,-1.82 V 42.773351 c 0,-1.62 -1.96,-2.44 -3.11,-1.29 z M 215.9,240.97335 H 107.46 l 108.44,-108.44 z"
                ></path>
                <path
                  fill="currentColor"
                  d="M 3.11,238.43335 238.49,3.0633514 c 0.99,-0.99 0.52,-2.57999999 -0.66,-2.99999999 -0.34,-0.12 -0.73,-0.06 -1.06,0.1 L 89.56,68.993351 c -7.81,3.65 -17.06,2.01 -23.15,-4.09 L 2.64,0.84335141 c -0.89,-0.98 -2.61,-0.43 -2.64,0.88999999 0,0.01 0,0.02 0,0.03 V 237.13335 c 0,1.62 1.96,2.44 3.11,1.29 z"
                ></path>
              </g>
            </svg>
            <div class="text-left">
              <span
                class="block text-2xl font-bold font-typewriter text-heading dark:text-(--color-heading-dark)"
                >Shareworthy Notes
              </span>
              <span
                class="block -mt-1 ml-0.5 text-md tracking-widest text-gray-500 font-typewriter"
              >
                half-crafted by mz
              </span>
            </div>
          </a>
          <ThemeIcon />
        </div>
      </header>

      <div
        id="floating-nav"
        class="fixed z-50 opacity-0 pointer-events-none transition-all duration-300 ease-out"
        style="top: 20px; left: 32px;"
      >
        <a href={basePath} class="flex items-center justify-center w-11 h-12">
          <svg
            aria-label="Home"
            width="44"
            height="48"
            class="w-11 h-12 text-heading dark:text-(--color-heading-dark)"
            viewBox="0 0 21.85 24"
          >
            <g transform="scale(0.08572244)">
              <path
                fill="currentColor"
                d="M 251.79,41.483351 16.41,276.86335 c -1.15,1.15 -0.33,3.11 1.29,3.11 h 235.37 c 1.01,0 1.82,-0.82 1.82,-1.82 V 42.773351 c 0,-1.62 -1.96,-2.44 -3.11,-1.29 z M 215.9,240.97335 H 107.46 l 108.44,-108.44 z"
              ></path>
              <path
                fill="currentColor"
                d="M 3.11,238.43335 238.49,3.0633514 c 0.99,-0.99 0.52,-2.57999999 -0.66,-2.99999999 -0.34,-0.12 -0.73,-0.06 -1.06,0.1 L 89.56,68.993351 c -7.81,3.65 -17.06,2.01 -23.15,-4.09 L 2.64,0.84335141 c -0.89,-0.98 -2.61,-0.43 -2.64,0.88999999 0,0.01 0,0.02 0,0.03 V 237.13335 c 0,1.62 1.96,2.44 3.11,1.29 z"
              ></path>
            </g>
          </svg>
        </a>
      </div>

      <div
        id="floating-theme"
        class="fixed z-50 opacity-0 pointer-events-none transition-all duration-300 ease-out"
        style="top: 20px; right: 32px;"
      >
        <button
          id="themeToggleFloating"
          aria-label="Toggle theme"
          class="theme-toggle"
          style="padding: 12px 0;"
        >
          <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24">
            <path
              class="sun"
              fill-rule="evenodd"
              d="M12 17.5a5.5 5.5 0 1 0 0-11 5.5 5.5 0 0 0 0 11zm0 1.5a7 7 0 1 0 0-14 7 7 0 0 0 0 14zm12-7a.8.8 0 0 1-.8.8h-2.4a.8.8 0 0 1 0-1.6h2.4a.8.8 0 0 1 .8.8zM4 12a.8.8 0 0 1-.8.8H.8a.8.8 0 0 1 0-1.6h2.5a.8.8 0 0 1 .8.8zm16.5-8.5a.8.8 0 0 1 0 1l-1.8 1.8a.8.8 0 0 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM6.3 17.7a.8.8 0 0 1 0 1l-1.7 1.8a.8.8 0 1 1-1-1l1.7-1.8a.8.8 0 0 1 1 0zM12 0a.8.8 0 0 1 .8.8v2.5a.8.8 0 0 1-1.6 0V.8A.8.8 0 0 1 12 0zm0 20a.8.8 0 0 1 .8.8v2.4a.8.8 0 0 1-1.6 0v-2.4a.8.8 0 0 1 .8-.8zM3.5 3.5a.8.8 0 0 1 1 0l1.8 1.8a.8.8 0 1 1-1 1L3.5 4.6a.8.8 0 0 1 0-1zm14.2 14.2a.8.8 0 0 1 1 0l1.8 1.7a.8.8 0 0 1-1 1l-1.8-1.7a.8.8 0 0 1 0-1z"
            ></path>
            <path
              class="moon"
              fill-rule="evenodd"
              d="M16.5 6A10.5 10.5 0 0 1 4.7 16.4 8.5 8.5 0 1 0 16.4 4.7l.1 1.3zm-1.7-2a9 9 0 0 1 .2 2 9 9 0 0 1-11 8.8 9.4 9.4 0 0 1-.8-.3c-.4 0-.8.3-.7.7a10 10 0 0 0 .3.8 10 10 0 0 0 9.2 6 10 10 0 0 0 4-19.2 9.7 9.7 0 0 0-.9-.3c-.3-.1-.7.3-.6.7a9 9 0 0 1 .3.8z"
            ></path>
          </svg>
        </button>
      </div>

      <style>
        .theme-toggle {
          border: 0;
          background: none;
          cursor: pointer;
          padding: 0;
          display: flex;
          align-items: center;
          justify-content: center;
          transition: opacity 0.2s;
        }
        .theme-toggle:hover {
          opacity: 0.7;
        }
        .sun {
          fill: #333;
        }
        .moon {
          fill: transparent;
        }
        :global(.dark) .sun {
          fill: transparent;
        }
        :global(.dark) .moon {
          fill: #eee;
        }
      </style>

      <main class="flex-1 max-w-180 w-full mx-auto px-4 sm:px-8 py-8">
        <slot />
      </main>

      <footer class="text-center py-8 text-gray-400 text-sm font-typewriter">
        <p>Marco Zausch</p>
      </footer>
    </div>

    <script>
      const header = document.getElementById("site-header");
      const floatingNav = document.getElementById("floating-nav");
      const floatingTheme = document.getElementById("floating-theme");
      const floatingToggle = document.getElementById("themeToggleFloating");

      let scrollTimeout;
      let isFloatingVisible = false;

      floatingToggle?.addEventListener("click", () => {
        const element = document.documentElement;
        element.classList.toggle("dark");
        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });

      window.addEventListener("scroll", () => {
        const currentScroll = window.scrollY;

        if (currentScroll > 100) {
          if (!isFloatingVisible) {
            header.classList.add("hidden");
            floatingNav.style.transform = "translateY(-10px)";
            floatingTheme.style.transform = "translateY(-10px)";
            floatingNav.classList.remove("opacity-0", "pointer-events-none");
            floatingTheme.classList.remove("opacity-0", "pointer-events-none");
            requestAnimationFrame(() => {
              floatingNav.style.transform = "translateY(0)";
              floatingTheme.style.transform = "translateY(0)";
            });
            isFloatingVisible = true;
          }
        } else {
          if (isFloatingVisible) {
            floatingNav.style.transform = "translateY(-10px)";
            floatingTheme.style.transform = "translateY(-10px)";
            floatingNav.classList.add("opacity-0", "pointer-events-none");
            floatingTheme.classList.add("opacity-0", "pointer-events-none");
            header.classList.remove("hidden");
            isFloatingVisible = false;
          }
        }
      });
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "typewriter";
    src: url("/Notes/fonts/typewcond_regular.otf") format("opentype");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "typewriter";
    src: url("/Notes/fonts/typewcond_bold.otf") format("opentype");
    font-weight: bold;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "code";
    src: url("/Notes/fonts/FiraCodeNerdFont-Light.ttf") format("truetype");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  body {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 18px;
    line-height: 1.7;
  }

  h1:first-child {
    margin-top: 0;
  }

  code,
  pre,
  kbd {
    font-family: "code", monospace;
  }

  code {
    background: #f4f4f4;
    padding: 0.2em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  pre {
    background: #f4f4f4;
    padding: 1em;
    border-radius: 4px;
    overflow-x: auto;
  }

  pre code {
    background: none;
    padding: 0;
  }

  :global(.dark) code,
  :global(.dark) pre {
    background: #2d2d2d;
  }
</style>
