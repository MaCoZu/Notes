---
import "../styles/global.css";
import ThemeIcon from "../components/ThemeIcon.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = "/Notes";
const basePath = base + "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={basePath + "mz_logo.svg"} />
    <title>{title}</title>
    <link
      rel="preload"
      href={basePath + "fonts/typewcond_regular.otf"}
      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href={basePath + "fonts/typewcond_bold.otf"}
      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href={basePath + "fonts/georgia.woff2"}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={basePath + "fonts/FiraCodeNerdFont-Light.ttf"}
      as="font"
      type="font/ttf"
      crossorigin
    />
  </head>
  <body class="bg-[var(--color-bg)] text-[var(--color-text)] dark:bg-[var(--color-bg-dark)] dark:text-[var(--color-text-dark)]">
    <div class="min-h-screen flex flex-col">
      <header class="border-b border-black/10 dark:border-white/10">
        <div class="mx-auto px-4 sm:px-8 py-4 flex justify-between items-center">
          <a href={basePath} class="flex items-center gap-4 no-underline">
            <svg
              alt="Logo"
              width="44"
              height="48"
              class="w-11 h-12 text-[var(--color-heading)] dark:text-[var(--color-heading-dark)]"
              viewBox="0 0 21.85 24"
            >
              <g transform="scale(0.08572244)">
                <path fill="currentColor" d="M 251.79,41.483351 16.41,276.86335 c -1.15,1.15 -0.33,3.11 1.29,3.11 h 235.37 c 1.01,0 1.82,-0.82 1.82,-1.82 V 42.773351 c 0,-1.62 -1.96,-2.44 -3.11,-1.29 z M 215.9,240.97335 H 107.46 l 108.44,-108.44 z" />
                <path fill="currentColor" d="M 3.11,238.43335 238.49,3.0633514 c 0.99,-0.99 0.52,-2.57999999 -0.66,-2.99999999 -0.34,-0.12 -0.73,-0.06 -1.06,0.1 L 89.56,68.993351 c -7.81,3.65 -17.06,2.01 -23.15,-4.09 L 2.64,0.84335141 c -0.89,-0.98 -2.61,-0.43 -2.64,0.88999999 0,0.01 0,0.02 0,0.03 V 237.13335 c 0,1.62 1.96,2.44 3.11,1.29 z" />
              </g>
            </svg>
            <div class="text-left">
              <span
                class="block text-2xl font-bold font-typewriter text-[var(--color-heading)] dark:text-[var(--color-heading-dark)]"
                >Shareworthy Notes
              </span>
              <span
                class="block -mt-1 ml-0.5 text-md tracking-widest text-gray-500 font-typewriter"
              >
                half-crafted by mz
              </span>
            </div>
          </a>
          <ThemeIcon />
        </div>
      </header>

      <main class="flex-1 max-w-[720px] w-full mx-auto px-4 sm:px-8 py-8">
        <slot />
      </main>

      <footer class="text-center py-8 text-gray-400 text-sm font-typewriter">
        <p>Marco Zausch</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "typewriter";
    src: url("/Notes/fonts/typewcond_regular.otf") format("opentype");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "typewriter";
    src: url("/Notes/fonts/typewcond_bold.otf") format("opentype");
    font-weight: bold;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "code";
    src: url("/Notes/fonts/FiraCodeNerdFont-Light.ttf") format("truetype");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  body {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 18px;
    line-height: 1.7;
  }

  h1:first-child {
    margin-top: 0;
  }

  a {
    color: var(--color-link);
  }

  :global(.dark) a {
    color: var(--color-link-dark);
  }

  code,
  pre,
  kbd {
    font-family: "code", monospace;
  }

  code {
    background: #f4f4f4;
    padding: 0.2em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  pre {
    background: #f4f4f4;
    padding: 1em;
    border-radius: 4px;
    overflow-x: auto;
  }

  pre code {
    background: none;
    padding: 0;
  }

  :global(.dark) code,
  :global(.dark) pre {
    background: #2d2d2d;
  }
</style>
